<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SwiftSearch.Views.SearchView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:SwiftSearch.Views"
    mc:Ignorable="d"
    Background="Transparent">
    
    <Page.Resources>
        <ThemeShadow x:Name="SharedShadow" />
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Semantic Discovery" 
                           Style="{ThemeResource SubtitleTextBlockStyle}" 
                           FontWeight="SemiBold" />
                <TextBlock Text="Locate your files conceptually with zero cloud dependencies" 
                           Style="{ThemeResource BodyTextBlockStyle}" 
                           Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
            </StackPanel>
            
            <!-- Quick Memory Controls in Header -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                <Border x:Name="ModelMemoryBadge" 
                        Background="{ThemeResource SystemFillColorSolidNeutralBackgroundBrush}" 
                        CornerRadius="12" 
                        Padding="12,6,12,6" 
                        BorderThickness="1" 
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Ellipse x:Name="ModelMemoryIndicator" Width="8" Height="8" Fill="#FFAAAAAA" VerticalAlignment="Center" />
                        <TextBlock x:Name="ModelMemoryStatusText" Text="RAM Offline" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
                <Button x:Name="QuickLoadUnloadButton" 
                        Content="Load AI to RAM" 
                        Style="{ThemeResource DefaultButtonStyle}"
                        CornerRadius="6"
                        Click="QuickLoadUnloadButton_Click"
                        VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- Search Bar and Settings Row -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Search input with glowing shadow border -->
            <TextBox x:Name="SearchTextBox" 
                     Grid.Column="0" 
                     PlaceholderText="Find a File" 
                     Height="54" 
                     FontSize="16"
                     VerticalContentAlignment="Center"
                     CornerRadius="8"
                     Padding="48,14,16,14"
                     Shadow="{StaticResource SharedShadow}"
                     Translation="0,0,8"
                     KeyDown="SearchTextBox_KeyDown">
                <TextBox.Resources>
                    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#FF34C759" />
                </TextBox.Resources>
            </TextBox>

            <!-- Injected Magnifying Glass Icon -->
            <FontIcon Glyph="&#xE721;" 
                      Grid.Column="0"
                      FontFamily="Segoe MDL2 Assets" 
                      FontSize="18" 
                      Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Center"
                      Margin="16,0,0,0"
                      IsHitTestVisible="False" />

            <!-- Search Button adjacent to text input -->
            <Button x:Name="SearchButton" 
                    Grid.Column="1" 
                    Content="Search" 
                    Style="{ThemeResource AccentButtonStyle}" 
                    Height="54" 
                    Width="90" 
                    Margin="16,0,0,0"
                    CornerRadius="8"
                    Click="SearchButton_Click" />

            <!-- Results Count (Top K) on the far right -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="24,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="Top results:" VerticalAlignment="Center" Margin="0,0,8,0" />
                <ComboBox x:Name="TopKComboBox" 
                          Width="80" 
                          CornerRadius="6"
                          SelectedIndex="0"
                          VerticalAlignment="Center">
                    <ComboBoxItem Content="10" Tag="10"/>
                    <ComboBoxItem Content="20" Tag="20"/>
                    <ComboBoxItem Content="30" Tag="30"/>
                    <ComboBoxItem Content="50" Tag="50"/>
                    <ComboBoxItem Content="100" Tag="100"/>
                </ComboBox>
            </StackPanel>
        </Grid>

        <!-- Main Workspace (Results Area / Loading spinner) -->
        <Grid Grid.Row="2">
            <!-- ScrollViewer for Unified Results -->
            <ScrollViewer x:Name="ResultsScrollViewer" VerticalScrollBarVisibility="Auto" Padding="0,0,16,12" Visibility="Collapsed">
                <StackPanel Spacing="24">
                    <!-- Everything Instant Matches -->
                    <StackPanel x:Name="EverythingSection" Visibility="Collapsed" Spacing="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Quick Results" 
                                       Style="{ThemeResource SubtitleTextBlockStyle}" 
                                       FontWeight="SemiBold" />
                            <Border Grid.Column="1" Background="{ThemeResource AccentAAFillColorDefaultBrush}" CornerRadius="4" Padding="6,2,6,2" VerticalAlignment="Center">
                                <TextBlock Text="Everything SDK" Foreground="White" FontSize="10" FontWeight="SemiBold" />
                            </Border>
                        </Grid>
                        
                        <ListView x:Name="EverythingListView" 
                                  SelectionMode="None" 
                                  IsItemClickEnabled="True"
                                  ItemClick="ResultsListView_ItemClick"
                                  ScrollViewer.VerticalScrollMode="Disabled">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Margin" Value="0,0,0,8" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="CornerRadius" Value="6" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="16,14,16,14">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <FontIcon Glyph="{Binding FileIcon}" 
                                                      FontFamily="Segoe MDL2 Assets" 
                                                      FontSize="20" 
                                                      Foreground="{Binding FileIconColor}" 
                                                      VerticalAlignment="Center" 
                                                      Margin="0,0,12,0" />
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                                                <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" FontSize="13" />
                                                <TextBlock Text="{Binding FilePath}" FontSize="11" Foreground="#B0B0B0" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>

                    <!-- Section Separator Line -->
                    <MenuFlyoutSeparator x:Name="SectionSeparator" Margin="0,8" Visibility="Collapsed" />

                    <!-- Semantic Conceptual Matches -->
                    <StackPanel x:Name="SemanticSection" Visibility="Collapsed" Spacing="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Content Matches" 
                                       Style="{ThemeResource SubtitleTextBlockStyle}" 
                                       FontWeight="SemiBold" />
                            
                            <ProgressRing x:Name="SemanticProgressRing" 
                                          Grid.Column="1" 
                                          IsActive="False" 
                                          Width="18" Height="18" 
                                          Margin="12,0,0,0" 
                                          VerticalAlignment="Center" />
                            
                            <Border Grid.Column="2" Background="{ThemeResource AccentAAFillColorDefaultBrush}" CornerRadius="4" Padding="6,2,6,2" Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Local AI Engine" Foreground="White" FontSize="10" FontWeight="SemiBold" />
                            </Border>
                        </Grid>

                        <ListView x:Name="SemanticListView" 
                                  SelectionMode="None" 
                                  IsItemClickEnabled="True"
                                  ItemClick="ResultsListView_ItemClick"
                                  ScrollViewer.VerticalScrollMode="Disabled">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Margin" Value="0,0,0,12" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="CornerRadius" Value="8" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="20,16,20,16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <FontIcon Glyph="{Binding FileIcon}" 
                                                      FontFamily="Segoe MDL2 Assets" 
                                                      FontSize="28" 
                                                      Foreground="{Binding FileIconColor}" 
                                                      VerticalAlignment="Center" 
                                                      Margin="0,0,16,0" />
                                            <Grid Grid.Column="1" Margin="0,0,16,0">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" FontSize="15" />
                                                <TextBlock Text="{Binding FilePath}" FontSize="11" Foreground="#B0B0B0" Margin="0,4,0,8" Grid.Row="1" />
                                                <Border Grid.Row="2" 
                                                        Background="#0AFFFFFF" 
                                                        BorderBrush="#FF34C759" 
                                                        BorderThickness="2,0,0,0" 
                                                        CornerRadius="4" 
                                                        Padding="12" 
                                                        Margin="0,10,0,0" 
                                                        HorizontalAlignment="Stretch">
                                                    <TextBlock FontSize="13" 
                                                               TextWrapping="Wrap" 
                                                               MaxLines="4"
                                                               TextTrimming="CharacterEllipsis"
                                                               Foreground="{ThemeResource SystemControlPageTextBaseHighBrush}"
                                                               LineHeight="18"
                                                               local:TextHighlight.FullText="{Binding ChunkText}"
                                                               local:TextHighlight.Query="{Binding Query}" />
                                                </Border>
                                            </Grid>
                                            <Border Background="{ThemeResource AccentAAFillColorDefaultBrush}" 
                                                    CornerRadius="6" 
                                                    Padding="8,4,8,4" 
                                                    Grid.Column="2" 
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding FormattedScore}" 
                                                           Foreground="White" 
                                                           FontSize="11" 
                                                           FontWeight="SemiBold" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                    
                    <!-- No Results Panel -->
                    <StackPanel x:Name="NoResultsPanel" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,60,0,0" Spacing="12">
                        <FontIcon Glyph="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                        <TextBlock Text="No matching files found" Style="{ThemeResource SubtitleTextBlockStyle}" HorizontalAlignment="Center" />
                        <TextBlock Text="Try adjusting watched folders or entering another term." FontSize="13" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Status Overlays (Downloading Model / No Results / Indexing) -->
            <Grid x:Name="OverlayPanel" Visibility="Collapsed" Background="{ThemeResource SolidBackgroundFillColorBaseBrush}" Opacity="0.95" CornerRadius="8">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                    <ProgressRing x:Name="OverlaySpinner" IsActive="True" Width="48" Height="48" />
                    <TextBlock x:Name="OverlayStatusText" 
                               Text="Downloading Embedding Engine..." 
                               FontSize="16" 
                               FontWeight="SemiBold" 
                               HorizontalAlignment="Center" />
                    <TextBlock Text="This happens only on first boot. Please wait while local weights are configured." 
                               FontSize="13" 
                               Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>
