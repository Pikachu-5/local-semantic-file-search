<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SwiftSearch.Views.SearchView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:SwiftSearch.Views"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Semantic Discovery" 
                       Style="{ThemeResource TitleTextBlockStyle}" 
                       FontWeight="SemiBold" />
            <TextBlock Text="Locate your files conceptually with zero cloud dependencies" 
                       Style="{ThemeResource BodyTextBlockStyle}" 
                       Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
        </StackPanel>

        <!-- Search Bar and Settings Row -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Search input with glowing shadow border -->
            <TextBox x:Name="SearchTextBox" 
                     Grid.Column="0" 
                     PlaceholderText="Enter your query... (e.g., 'artificial intelligence notes')" 
                     Height="42" 
                     VerticalContentAlignment="Center"
                     CornerRadius="8"
                     Padding="12,0,12,0"
                     KeyDown="SearchTextBox_KeyDown" />

            <!-- Results Count (Top K) -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="Top results:" VerticalAlignment="Center" Margin="0,0,8,0" />
                <Slider x:Name="TopKSlider" 
                        Width="100" 
                        Minimum="5" 
                        Maximum="50" 
                        Value="10" 
                        TickFrequency="5"
                        SnapsTo="Ticks"
                        Header=""
                        VerticalAlignment="Center" />
            </StackPanel>

            <Button x:Name="SearchButton" 
                    Grid.Column="2" 
                    Content="Search" 
                    Style="{ThemeResource AccentButtonStyle}" 
                    Height="42" 
                    Width="90" 
                    Margin="16,0,0,0"
                    CornerRadius="8"
                    Click="SearchButton_Click" />
        </Grid>

        <!-- Main Workspace (Results Area / Loading spinner) -->
        <Grid Grid.Row="2">
            <!-- Results ListView -->
            <ListView x:Name="ResultsListView" 
                      SelectionMode="None" 
                      IsItemClickEnabled="True"
                      ItemClick="ResultsListView_ItemClick"
                      Padding="0,0,0,12">
                
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Margin" Value="0,0,0,12" />
                        <Setter Property="Padding" Value="0" />
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <!-- Glassmorphic Card -->
                        <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                                BorderThickness="1" 
                                CornerRadius="8" 
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                Padding="16">
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- File Icon -->
                                <FontIcon Glyph="{Binding FileIcon}" 
                                          FontFamily="Segoe MDL2 Assets" 
                                          FontSize="28" 
                                          Foreground="{Binding FileIconColor}" 
                                          VerticalAlignment="Center" 
                                          Margin="0,0,16,0" 
                                          Grid.Column="0" />

                                <!-- Text Details -->
                                <Grid Grid.Column="1" Margin="0,0,16,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- File Name -->
                                    <TextBlock Text="{Binding FileName}" 
                                               FontWeight="SemiBold" 
                                               FontSize="15" 
                                               Grid.Row="0" />

                                    <!-- Folder Path -->
                                    <TextBlock Text="{Binding FilePath}" 
                                               FontSize="11" 
                                               Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" 
                                               Margin="0,2,0,8" 
                                               Grid.Row="1" />

                                    <!-- Text Context Snippet with Dynamic Highlighting -->
                                    <TextBlock FontSize="13" 
                                               TextWrapping="Wrap" 
                                               Foreground="{ThemeResource SystemControlPageTextBaseHighBrush}"
                                               LineHeight="18"
                                               Grid.Row="2"
                                               local:TextHighlight.FullText="{Binding ChunkText}"
                                               local:TextHighlight.Query="{Binding Query}" />
                                </Grid>

                                <!-- Match relevance score badge -->
                                <Border Background="{ThemeResource AccentAAFillColorDefaultBrush}" 
                                        CornerRadius="6" 
                                        Padding="8,4,8,4" 
                                        Grid.Column="2" 
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding FormattedScore}" 
                                               Foreground="White" 
                                               FontSize="11" 
                                               FontWeight="SemiBold" />
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Status Overlays (Downloading Model / No Results / Indexing) -->
            <Grid x:Name="OverlayPanel" Visibility="Collapsed" Background="{ThemeResource SolidBackgroundFillColorBaseBrush}" Opacity="0.95" CornerRadius="8">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                    <ProgressRing x:Name="OverlaySpinner" IsActive="True" Width="48" Height="48" />
                    <TextBlock x:Name="OverlayStatusText" 
                               Text="Downloading Embedding Engine..." 
                               FontSize="16" 
                               FontWeight="SemiBold" 
                               HorizontalAlignment="Center" />
                    <TextBlock Text="This happens only on first boot. Please wait while local weights are configured." 
                               FontSize="13" 
                               Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>
