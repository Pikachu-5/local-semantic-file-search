<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SwiftSearch.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Page Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <TextBlock Text="Settings Manager" 
                           Style="{ThemeResource TitleTextBlockStyle}" 
                           FontWeight="SemiBold" />
                <TextBlock Text="Configure directory watchdogs, scan exclusions, and neural search engines" 
                           Style="{ThemeResource BodyTextBlockStyle}" 
                           Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
            </StackPanel>

            <!-- Settings Layout Grid -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="1.5*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Left Column Settings -->
                <StackPanel Grid.Column="0" Margin="0,0,16,0" Spacing="20">
                    
                    <!-- Embedding Engine Selection -->
                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                            BorderThickness="1" 
                            CornerRadius="8" 
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            Padding="20">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Embedding Model Engine" FontWeight="SemiBold" FontSize="16" />
                            <TextBlock Text="Neural model used to translate your file contents into vectors." 
                                       FontSize="12" 
                                       Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" 
                                       TextWrapping="Wrap" />
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <RadioButton x:Name="BgeModelRadio" 
                                             Content="BGE-Small-EN-v1.5 (Default)" 
                                             GroupName="ModelEngine" 
                                             IsChecked="True" 
                                             Checked="ModelRadio_Checked" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                    <TextBlock x:Name="BgeStatusText" Text="Not Downloaded" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                    <Button x:Name="BgeDownloadButton" Content="Download" Click="DownloadBgeButton_Click" CornerRadius="4" Padding="12,4,12,4" FontSize="12" />
                                    <Button x:Name="BgeMemoryButton" Content="Load" Click="BgeMemoryButton_Click" CornerRadius="4" Padding="12,4,12,4" FontSize="12" Visibility="Collapsed" />
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="High-speed retrieval. Model size ~130MB. Perfect for standard laptops." 
                                       FontSize="11" 
                                       Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" 
                                       Margin="28,-8,0,0" 
                                       TextWrapping="Wrap" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <RadioButton x:Name="NomicModelRadio" 
                                             Content="Nomic-Embed-Text-v1.5" 
                                             GroupName="ModelEngine" 
                                             Checked="ModelRadio_Checked" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                    <TextBlock x:Name="NomicStatusText" Text="Not Downloaded" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                    <Button x:Name="NomicDownloadButton" Content="Download" Click="DownloadNomicButton_Click" CornerRadius="4" Padding="12,4,12,4" FontSize="12" />
                                    <Button x:Name="NomicMemoryButton" Content="Load" Click="NomicMemoryButton_Click" CornerRadius="4" Padding="12,4,12,4" FontSize="12" Visibility="Collapsed" />
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Deep semantic context. Model size ~280MB. Higher RAM usage." 
                                       FontSize="11" 
                                       Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" 
                                       Margin="28,-8,0,0" 
                                       TextWrapping="Wrap" />
                            
                            <!-- Model Download Progress Card -->
                            <StackPanel x:Name="DownloadProgressPanel" Spacing="8" Margin="0,12,0,0" Visibility="Collapsed">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="DownloadStatusText" Text="Downloading BGE-Small-EN-v1.5..." FontSize="12" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                    <TextBlock x:Name="DownloadProgressPercent" Text="45%" FontWeight="SemiBold" FontSize="12" Grid.Column="1" />
                                </Grid>
                                <ProgressBar x:Name="DownloadProgressBar" Value="45" Minimum="0" Maximum="100" Height="6" CornerRadius="3" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Appearance / Theme Selector Card -->
                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                            BorderThickness="1" 
                            CornerRadius="8" 
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            Padding="20">
                        <StackPanel Spacing="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="App Theme" FontWeight="SemiBold" FontSize="16" />
                                    <TextBlock Text="Choose your preferred visual style." 
                                               FontSize="12" 
                                               Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" 
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <FontIcon Glyph="&#xE706;" 
                                          FontFamily="Segoe MDL2 Assets" 
                                          FontSize="20" 
                                          Grid.Column="1" 
                                          Foreground="{ThemeResource AccentAAFillColorDefaultBrush}" 
                                          VerticalAlignment="Center" />
                            </Grid>
                            
                            <ComboBox x:Name="ThemeComboBox" 
                                      HorizontalAlignment="Stretch" 
                                      Margin="0,4,0,0" 
                                      SelectionChanged="ThemeComboBox_SelectionChanged" 
                                      CornerRadius="4">
                                <ComboBoxItem Content="System Default" Tag="Default" />
                                <ComboBoxItem Content="Light" Tag="Light" />
                                <ComboBoxItem Content="Dark" Tag="Dark" />
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <!-- Developer Options Card -->
                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                            BorderThickness="1" 
                            CornerRadius="8" 
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            Padding="20">
                        <StackPanel Spacing="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Developer Logs" FontWeight="SemiBold" FontSize="16" />
                                    <TextBlock Text="Enable deep system diagnostics and live crawler logs." 
                                               FontSize="12" 
                                               Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" 
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <ToggleSwitch x:Name="DevLogsToggle" 
                                              Grid.Column="1" 
                                              Toggled="DevLogsToggle_Toggled" 
                                              OnContent="Enabled" 
                                              OffContent="Disabled" 
                                              VerticalAlignment="Center" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Database Statistics Status -->
                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                            BorderThickness="1" 
                            CornerRadius="8" 
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            Padding="20">
                        <StackPanel Spacing="16">
                            <TextBlock Text="Database &amp; Status" FontWeight="SemiBold" FontSize="16" />
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Total Files Crawled:" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                <TextBlock x:Name="StatsFilesText" Text="127 files" FontWeight="SemiBold" Grid.Column="1" />
                            </Grid>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Vector Index Chunks:" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                <TextBlock x:Name="StatsVectorsText" Text="1,842 vectors" FontWeight="SemiBold" Grid.Column="1" />
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Live File Observer:" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                <TextBlock x:Name="StatsWatchdogText" Text="Active Monitoring" Foreground="Green" FontWeight="SemiBold" Grid.Column="1" />
                            </Grid>
                            
                            <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" Margin="0,4,0,4" />
                            
                            <StackPanel Spacing="8">
                                <TextBlock Text="Vector Database Storage Directory:" FontSize="13" FontWeight="SemiBold" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="DbDirText" Text="%LocalAppData%\SwiftSearch\db" 
                                               FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" 
                                               TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,0,12,0" />
                                    <Button x:Name="OpenDbDirButton" Content="Open Folder" Click="OpenDbDirButton_Click" 
                                            Style="{ThemeResource DefaultButtonStyle}" Grid.Column="1" CornerRadius="4" />
                                </Grid>
                            </StackPanel>

                            <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" Margin="0,4,0,4" />

                            <StackPanel Spacing="8">
                                <TextBlock Text="Index Actions (Danger Zone):" FontSize="13" FontWeight="SemiBold" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Completely erase all indexed vector databases and reset watched folder settings." 
                                               FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" 
                                               TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,0,12,0" />
                                    <Button x:Name="DeleteVectorsButton" Content="Delete All Vectors" Click="DeleteVectorsButton_Click" 
                                            Foreground="#FFFF453A" Style="{ThemeResource DefaultButtonStyle}" Grid.Column="1" CornerRadius="4" />
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Right Column Settings -->
                <StackPanel Grid.Column="1" Margin="16,0,0,0" Spacing="20">
                    
                    <!-- Watched Folder Management -->
                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                            BorderThickness="1" 
                            CornerRadius="8" 
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            Padding="20">
                        <StackPanel Spacing="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Watched Directories" FontWeight="SemiBold" FontSize="16" VerticalAlignment="Center" />
                                <Button x:Name="AddFolderButton" 
                                        Content="Add Folder" 
                                        Style="{ThemeResource AccentButtonStyle}" 
                                        Grid.Column="1" 
                                        Click="AddFolderButton_Click" 
                                        CornerRadius="4" />
                            </Grid>

                            <!-- Folder List View -->
                            <ListView x:Name="FoldersListView" Height="140" SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="0,4,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                            <Button Content="Remove" 
                                                    Grid.Column="1" 
                                                    Style="{ThemeResource DefaultButtonStyle}" 
                                                    Click="RemoveFolderButton_Click" 
                                                    Padding="8,4,8,4" 
                                                    CornerRadius="4" 
                                                    CommandParameter="{Binding}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <!-- Advanced Filter Rules -->
                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                            BorderThickness="1" 
                            CornerRadius="8" 
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            Padding="20">
                        <StackPanel Spacing="16">
                            <TextBlock Text="Advanced Indexing Rules" FontWeight="SemiBold" FontSize="16" />
                            
                            <!-- Excluded Directories -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="Excluded Folder Patterns:" FontWeight="SemiBold" FontSize="13" />
                                <TextBlock Text="Any subfolders with these names are entirely skipped during crawler scans." 
                                           FontSize="11" 
                                           Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                <TextBox x:Name="ExclusionsTextBox" 
                                         Text="node_modules, .git, .venv, bin, obj" 
                                         CornerRadius="6" 
                                         LostFocus="Rules_Changed" />
                            </StackPanel>

                            <!-- Extensions List -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="Allowed File Extensions:" FontWeight="SemiBold" FontSize="13" />
                                <TextBlock Text="Only files matching these formats are scanned and parsed into LanceDB." 
                                           FontSize="11" 
                                           Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                <TextBox x:Name="ExtensionsTextBox" 
                                         Text=".pdf, .md, .txt, .py" 
                                         CornerRadius="6" 
                                         LostFocus="Rules_Changed" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
