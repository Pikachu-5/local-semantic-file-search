<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SwiftSearch.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Page Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <TextBlock Text="Settings Manager" 
                           Style="{ThemeResource TitleTextBlockStyle}" 
                           FontWeight="SemiBold" />
                <TextBlock Text="Configure directory watchdogs, scan exclusions, and neural search engines" 
                           Style="{ThemeResource BodyTextBlockStyle}" 
                           Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
            </StackPanel>

            <!-- Settings Layout Grid -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="1.5*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Left Column Settings -->
                <StackPanel Grid.Column="0" Margin="0,0,16,0" Spacing="20">
                    
                    <!-- Embedding Engine Selection -->
                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                            BorderThickness="1" 
                            CornerRadius="8" 
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            Padding="20">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Embedding Model Engine" FontWeight="SemiBold" FontSize="16" />
                            <TextBlock Text="Neural model used to translate your file contents into vectors." 
                                       FontSize="12" 
                                       Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" 
                                       TextWrapping="Wrap" />
                            
                            <RadioButton x:Name="BgeModelRadio" 
                                         Content="BGE-Small-EN-v1.5 (Default)" 
                                         GroupName="ModelEngine" 
                                         IsChecked="True" 
                                         Checked="ModelRadio_Checked" />
                            <TextBlock Text="High-speed retrieval. Model size ~130MB. Perfect for standard laptops." 
                                       FontSize="11" 
                                       Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" 
                                       Margin="28,-8,0,0" 
                                       TextWrapping="Wrap" />

                            <RadioButton x:Name="NomicModelRadio" 
                                         Content="Nomic-Embed-Text-v1.5" 
                                         GroupName="ModelEngine" 
                                         Checked="ModelRadio_Checked" />
                            <TextBlock Text="Deep semantic context. Model size ~280MB. Higher RAM usage." 
                                       FontSize="11" 
                                       Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" 
                                       Margin="28,-8,0,0" 
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <!-- Database Statistics Status -->
                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                            BorderThickness="1" 
                            CornerRadius="8" 
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            Padding="20">
                        <StackPanel Spacing="16">
                            <TextBlock Text="Database &amp; Status" FontWeight="SemiBold" FontSize="16" />
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Total Files Crawled:" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                <TextBlock x:Name="StatsFilesText" Text="127 files" FontWeight="SemiBold" Grid.Column="1" />
                            </Grid>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Vector Index Chunks:" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                <TextBlock x:Name="StatsVectorsText" Text="1,842 vectors" FontWeight="SemiBold" Grid.Column="1" />
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Live File Observer:" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                <TextBlock x:Name="StatsWatchdogText" Text="Active Monitoring" Foreground="Green" FontWeight="SemiBold" Grid.Column="1" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Right Column Settings -->
                <StackPanel Grid.Column="1" Margin="16,0,0,0" Spacing="20">
                    
                    <!-- Watched Folder Management -->
                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                            BorderThickness="1" 
                            CornerRadius="8" 
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            Padding="20">
                        <StackPanel Spacing="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Watched Directories" FontWeight="SemiBold" FontSize="16" VerticalAlignment="Center" />
                                <Button x:Name="AddFolderButton" 
                                        Content="Add Folder" 
                                        Style="{ThemeResource AccentButtonStyle}" 
                                        Grid.Column="1" 
                                        Click="AddFolderButton_Click" 
                                        CornerRadius="4" />
                            </Grid>

                            <!-- Folder List View -->
                            <ListView x:Name="FoldersListView" Height="140" SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="0,4,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                            <Button Content="Remove" 
                                                    Grid.Column="1" 
                                                    Style="{ThemeResource DefaultButtonStyle}" 
                                                    Click="RemoveFolderButton_Click" 
                                                    Padding="8,4,8,4" 
                                                    CornerRadius="4" 
                                                    CommandParameter="{Binding}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <!-- Advanced Filter Rules -->
                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                            BorderThickness="1" 
                            CornerRadius="8" 
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            Padding="20">
                        <StackPanel Spacing="16">
                            <TextBlock Text="Advanced Indexing Rules" FontWeight="SemiBold" FontSize="16" />
                            
                            <!-- Excluded Directories -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="Excluded Folder Patterns:" FontWeight="SemiBold" FontSize="13" />
                                <TextBlock Text="Any subfolders with these names are entirely skipped during crawler scans." 
                                           FontSize="11" 
                                           Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                <TextBox x:Name="ExclusionsTextBox" 
                                         Text="node_modules, .git, .venv, bin, obj" 
                                         CornerRadius="6" 
                                         LostFocus="Rules_Changed" />
                            </StackPanel>

                            <!-- Extensions List -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="Allowed File Extensions:" FontWeight="SemiBold" FontSize="13" />
                                <TextBlock Text="Only files matching these formats are scanned and parsed into LanceDB." 
                                           FontSize="11" 
                                           Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                <TextBox x:Name="ExtensionsTextBox" 
                                         Text=".pdf, .md, .txt, .py" 
                                         CornerRadius="6" 
                                         LostFocus="Rules_Changed" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
