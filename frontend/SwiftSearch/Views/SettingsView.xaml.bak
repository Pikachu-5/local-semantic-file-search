<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SwiftSearch.Views.SettingsView"
    x:Name="SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:SwiftSearch.Core.Converters"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBooleanToVisibilityConverter x:Key="InvBoolToVis" />
        <converters:BooleanToInverseConverter x:Key="BoolToInv" />

        <SolidColorBrush x:Key="AccentBrush" Color="{ThemeResource SystemAccentColor}" />

        <Style x:Key="SettingsCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>
    </Page.Resources>

    <Grid Margin="24,12,24,24">
        <!-- Main ScrollViewer for settings sections -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="4">
                <!-- Header -->
                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="System Settings" 
                               FontSize="28" 
                               FontWeight="SemiBold"
                               FontFamily="Segoe UI Variable Display"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                    <TextBlock Text="Configure local search directories, index filters, and embedding models" 
                               FontSize="14" 
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <!-- Section A: Performance Stats -->
                <Border Style="{StaticResource SettingsCardStyle}">
                    <StackPanel Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE9D2;" FontSize="20" Foreground="{StaticResource AccentBrush}" />
                            <TextBlock Text="System Status &amp; Performance" FontSize="18" FontWeight="SemiBold" />
                        </StackPanel>

                        <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto">
                            <!-- Indexed Files Card -->
                            <StackPanel Grid.Column="0" Spacing="4" HorizontalAlignment="Center">
                                <TextBlock Text="Total Files Indexed" FontSize="12.5" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding TotalFiles}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" />
                            </StackPanel>

                            <!-- Vectors generated Card -->
                            <StackPanel Grid.Column="1" Spacing="4" HorizontalAlignment="Center">
                                <TextBlock Text="Vectors Generated" FontSize="12.5" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding TotalVectors}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" />
                            </StackPanel>

                            <!-- Watchdog Card -->
                            <StackPanel Grid.Column="2" Spacing="4" HorizontalAlignment="Center">
                                <TextBlock Text="Active Watchdog" FontSize="12.5" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
                                <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center" Margin="0,4,0,0">
                                    <Ellipse Width="10" Height="10" 
                                             Fill="{ThemeResource SystemFillColorSuccessBrush}" 
                                             Visibility="{Binding IsWatchdogRunning, Converter={StaticResource BoolToVis}}" />
                                    <Ellipse Width="10" Height="10" 
                                             Fill="{ThemeResource SystemFillColorCautionBrush}" 
                                             Visibility="{Binding IsWatchdogRunning, Converter={StaticResource InvBoolToVis}}" />
                                    <TextBlock Text="{Binding IsWatchdogRunning, Converter={StaticResource BoolToInv}, ConverterParameter='Disabled'}" 
                                               FontSize="15" FontWeight="SemiBold" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Section B: Embedding Model Engine -->
                <Border Style="{StaticResource SettingsCardStyle}" IsEnabled="{Binding IsDownloadingModel, Converter={StaticResource BoolToInv}}">
                    <StackPanel Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE95A;" FontSize="20" Foreground="{StaticResource AccentBrush}" />
                            <TextBlock Text="Embedding Model Engine" FontSize="18" FontWeight="SemiBold" />
                        </StackPanel>

                        <TextBlock Text="Choose which natural language model processes files. Toggling automatically transitions indices." 
                                   FontSize="13.5" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                        <StackPanel Spacing="12">
                            <RadioButton IsChecked="{Binding IsBgeSelected, Mode=TwoWay}">
                                <StackPanel Margin="6,0,0,0">
                                    <TextBlock Text="BGE-Small-EN-v1.5 (Recommended)" FontSize="14.5" FontWeight="SemiBold" />
                                    <TextBlock Text="Fast &amp; lightweight (130MB). Excellent for standard laptops, utilizing extremely quick local CPU inference." 
                                               FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                            </RadioButton>

                            <RadioButton IsChecked="{Binding IsNomicSelected, Mode=TwoWay}">
                                <StackPanel Margin="6,0,0,0">
                                    <TextBlock Text="Nomic-Embed-Text-v1.5" FontSize="14.5" FontWeight="SemiBold" />
                                    <TextBlock Text="High accuracy (540MB). Supports massive token windows, recommended if indexing long research papers." 
                                               FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                            </RadioButton>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Section C: Watched Directories -->
                <Border Style="{StaticResource SettingsCardStyle}">
                    <StackPanel Spacing="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE8B7;" FontSize="20" Foreground="{StaticResource AccentBrush}" />
                                <TextBlock Text="Watched Search Folders" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                            </StackPanel>
                            
                            <Button Grid.Column="1" 
                                    Command="{Binding AddFolderCommand}"
                                    Style="{StaticResource AccentButtonStyle}"
                                    IsEnabled="{Binding IsDownloadingModel, Converter={StaticResource BoolToInv}}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE109;" FontSize="12" />
                                    <TextBlock Text="Add Watch Folder" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <TextBlock Text="Directories currently monitored by SwiftSearch. Subdirectories are watched recursively in real-time." 
                                   FontSize="13.5" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                        <!-- List of folders -->
                        <Grid MinHeight="100">
                            <!-- Empty folder watched notification -->
                            <TextBlock Text="No directories are currently watched. Add a folder to begin indexing local content." 
                                       Visibility="{Binding WatchedFolders.Count, Converter={StaticResource InvBoolToVis}}"
                                       FontSize="13.5" FontStyle="Italic" Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,20,0,20" />

                            <ListView ItemsSource="{Binding WatchedFolders}"
                                      SelectionMode="None"
                                      Visibility="{Binding WatchedFolders.Count, Converter={StaticResource BoolToVis}}">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,4">
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                <FontIcon Glyph="&#xE8B7;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                <TextBlock Text="{Binding}" FontSize="13.5" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                            </StackPanel>
                                            
                                            <Button Grid.Column="1" 
                                                    Command="{Binding DataContext.RemoveFolderCommand, ElementName=SettingsPage}"
                                                    CommandParameter="{Binding}"
                                                    Background="Transparent"
                                                    BorderBrush="Transparent"
                                                    Padding="4">
                                                <FontIcon Glyph="&#xE10A;" FontSize="12" Foreground="{ThemeResource SystemFillColorDangerBrush}" />
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Section D: Rules & Exclusions -->
                <Border Style="{StaticResource SettingsCardStyle}" IsEnabled="{Binding IsDownloadingModel, Converter={StaticResource BoolToInv}}">
                    <StackPanel Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xF12B;" FontSize="20" Foreground="{StaticResource AccentBrush}" />
                            <TextBlock Text="Indexing Rules &amp; Exclusions" FontSize="18" FontWeight="SemiBold" />
                        </StackPanel>

                        <!-- Exclude dirs -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="Excluded Directories" FontSize="14" FontWeight="SemiBold" />
                            <TextBlock Text="Directories to ignore during scanning (comma-separated, e.g. node_modules, .git, .venv, bin, obj)" 
                                       FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBox Text="{Binding ExcludedDirsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                     FontSize="13.5" />
                        </StackPanel>

                        <!-- Extensions -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="Included File Extensions" FontSize="14" FontWeight="SemiBold" />
                            <TextBlock Text="Parse files with these extensions only (comma-separated, e.g. .txt, .md, .pdf, .py, .cs)" 
                                       FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBox Text="{Binding IncludedExtensionsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                     FontSize="13.5" />
                        </StackPanel>

                        <!-- Save button -->
                        <Button Command="{Binding SaveRulesCommand}"
                                Width="140"
                                Height="36"
                                Margin="0,8,0,0"
                                Style="{StaticResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE74E;" FontSize="12" />
                                <TextBlock Text="Save Rules" FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Dynamic loader modal when model transitions are running -->
        <Grid Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
              Opacity="0.95"
              Visibility="{Binding IsDownloadingModel, Converter={StaticResource BoolToVis}}"
              CornerRadius="8"
              Margin="-12">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
                <ProgressRing IsActive="True" Width="60" Height="60" />
                <TextBlock Text="Transitioning Core Model..." 
                           FontSize="20" 
                           FontWeight="SemiBold" 
                           HorizontalAlignment="Center" />
                <TextBlock Text="The backend is dynamically loading the selected model files and spinning up database endpoints. This may take up to a minute." 
                           FontSize="13" 
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                           HorizontalAlignment="Center" 
                           MaxWidth="340" 
                           TextAlignment="Center" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
